{
  "name": "mega-md-pro-max",
  "version": "5.3.0",
  "description": "Ultra-High Performance Multi-Device WhatsApp Bot - Pro Max Edition",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "pro": "node --expose-gc --turbo-fast-path --no-warnings index.js",
    "max": "node --max-old-space-size=1024 --gc-interval=100 --optimize-for-size index.js",
    "turbo": "pm2 start index.js --name wizzy-bot --cron-restart=\"0 */6 * * *\"",
    "cleanup": "rm -rf .cache .index.js temp_* session/*.json",
    "install:pro": "npm install --no-audit --no-fund --omit=dev --legacy-peer-deps",
    "update:core": "npm install git+https://github.com/newboytz/wizzy.git"
  },
  "keywords": [
    "whatsapp-bot",
    "mega-md",
    "pro-max",
    "multi-device"
  ],
  "homepage": "https://github.com/newboytz/wizzy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/newboytz/wizzy.git"
  },
  "author": "newboytz",
  "license": "MIT",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "acrcloud": "^1.4.0",
    "api-qasim": "^3.2.10",
    "awesome-phonenumber": "^5.9.0",
    "axios": "^1.8.4",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "file-type": "^16.5.4",
    "form-data": "^4.0.1",
    "fs-extra": "^11.2.0",
    "human-readable": "^0.2.1",
    "libphonenumber-js": "^1.11.18",
    "link-preview-js": "^3.0.5",
    "megajs": "^1.3.9",
    "moment-timezone": "^0.5.43",
    "mongoose": "^9.0.2",
    "mumaker": "^2.0.0",
    "mysql2": "^3.16.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0",
    "performance-now": "^2.1.0",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "ruhend-scraper": "^9.0.8",
    "simple-git": "^3.30.0",
    "syntax-error": "^1.4.0",
    "stickers-formatter": "^0.0.1",
    "yt-search": "^2.12.1",
    "pino": "^9.0.0"
  }
}
